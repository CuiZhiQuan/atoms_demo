# LLM Configuration
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Race mode: additional models (comma-separated)
# Leave empty to use LLM_MODEL for all race lanes
LLM_RACE_MODELS=deepseek-chat,claude-3-5-sonnet-20240620

# Server
HOST=0.0.0.0
PORT=8000

# Auth
JWT_SECRET=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Deploy — generated apps are deployed to Netlify
# (Frontend is deployed separately to Cloudflare Pages)
NETLIFY_TOKEN=nfp-your-netlify-personal-access-token